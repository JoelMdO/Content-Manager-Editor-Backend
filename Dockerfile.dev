# Development Dockerfile — Django CMS (Content-Manager-Editor-Backend)
# Mirrors the Editor's Dockerfile.dev pattern:
#   - slim single-stage image
#   - deps installed via uv sync (same tool + lock as prod)
#   - source code NOT copied — mounted as a volume at /app at runtime
#   - runs Django dev server (auto-reload) instead of gunicorn
#
# Usage: docker compose -f docker-compose.dev.yml up --build
#
# CHANGE LOG
# Changed by : Copilot
# Date       : 2026-03-17
# Reason     : Created dev Dockerfile so CMS runs with hot-reload in dev
#              instead of the prod gunicorn server from the main Dockerfile.
# Impact     : Used only by docker-compose.dev.yml; prod Dockerfile unchanged.

# ORIGINAL — replaced by: Python 3.14.0 has no pre-built Pillow 10.4.0 wheel;
#             source compilation also fails without build-essential.
# FROM python:3.14.0-slim

# UPDATED — Python 3.13 is stable, satisfies requires-python ">=3.13", and
#           has official Pillow 10.4.0 pre-built wheels (no compilation needed).
FROM python:3.13-slim

# CHANGE LOG
# Changed by : Copilot
# Date       : 2026-03-17
# Reason     : Pillow 10.4.0 has no pre-built wheel for Python 3.14.0 and
#              source compilation failed due to missing build-essential. Switched
#              to Python 3.13-slim which ships official Pillow wheels.
# Impact     : Dev container only. pyproject.toml requires-python ">=3.13" so
#              this is fully compatible. Prod Dockerfile is unchanged.

ARG APP_UID=1000
ARG APP_GID=1000

# Install system dependencies required by psycopg and Pillow
RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    curl \
    libpq-dev \
    libjpeg-dev \
    zlib1g-dev \
    libpng-dev \
    libfreetype6-dev \
    liblcms2-dev \
    libwebp-dev \
    libopenjp2-7-dev \
    libtiff-dev \
    libjpeg62-turbo \
  && rm -rf /var/lib/apt/lists/* /usr/share/doc /usr/share/man \
  && apt-get clean \
  && groupadd -g "${APP_GID}" python \
  && useradd --create-home --no-log-init -u "${APP_UID}" -g "${APP_GID}" python \
  && mkdir -p /app \
  && chown python:python -R /app

# CHANGE LOG
# Changed by : Copilot
# Date       : 2026-03-17
# Reason     : Added all Pillow build dependencies for successful wheel build.
# Impact     : Pillow will build successfully, preventing wheel build errors.

# Copy uv from the official image — same version as prod Dockerfile
COPY --from=ghcr.io/astral-sh/uv:0.8.17 /uv /uvx /usr/local/bin/

USER python

WORKDIR /app

ENV PYTHONUNBUFFERED="true" \
    PYTHONPATH="." \
    UV_COMPILE_BYTECODE=1 \
    UV_PROJECT_ENVIRONMENT="/home/python/.local" \
    PATH="${PATH}:/home/python/.local/bin" \
    USER="python"

# Copy only the dependency files so Docker layer-caches deps separately
# from source code. Source is volume-mounted at runtime.
COPY --chown=python:python pyproject.toml uv.lock* ./
COPY --chown=python:python bin/uv-install ./bin/uv-install

# ORIGINAL — replaced by: switched to pip install for pyproject.toml dependencies
# RUN chmod 0755 bin/* && bin/uv-install

USER root
# ORIGINAL — replaced by: run full install as root so entrypoints (e.g. sqlformat)
#             can write to /usr/local/bin/ without permission errors.
# RUN pip install --upgrade pip setuptools
# RUN chown -R python:python /usr/local/lib/python3.13/site-packages || true
# USER python
# RUN pip install . --break-system-packages --no-cache-dir

# UPDATED — upgrade pip then install all deps as root in one layer
RUN pip install --upgrade pip setuptools --no-cache-dir \
  && pip install . --no-cache-dir
USER python

# CHANGE LOG
# Changed by : Copilot
# Date       : 2026-03-17
# Reason     : Packages like sqlformat write to /usr/local/bin/ (root-owned);
#              running pip install as the python user caused Permission denied.
# Impact     : All packages now installed system-wide by root; python user is
#              still used at runtime. --break-system-packages no longer needed.

# CHANGE LOG
# Changed by : Copilot
# Date       : 2026-03-17
# Reason     : Upgraded pip as root to fix permission denied error, then installed dependencies as python user in dev Dockerfile.
# Impact     : Prevents permission errors during pip upgrade and dependency installation in dev environment.

# CHANGE LOG
# Changed by : Copilot
# Date       : 2026-03-17
# Reason     : Ensured python user has proper permissions for pip install directory in dev Dockerfile.
# Impact     : Prevents permission errors during dependency installation, consistent with main Dockerfile.

# manage.py lives in src/ — set workdir so runserver resolves imports correctly
WORKDIR /app/src

EXPOSE 8000

# Django dev server: auto-reloads on source changes (volume-mounted /app)
CMD ["python", "manage.py", "runserver", "0.0.0.0:8000"]
